{
  "compilerOptions": {
    "target": "es2023",
    "module": "commonjs",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "noEmit": false,
    "outDir": ".tmp-test",
    "rootDir": ".",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "files": [
    "src/lib/cardBenefits.ts",
    "src/lib/expenseFilters.ts",
    "src/lib/format.ts",
    "src/lib/giftcards.ts",
    "src/lib/returns.ts",
    "src/lib/sheets.ts",
    "src/lib/tags.ts",
    "src/lib/types.ts"
  ]
}
